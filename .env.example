# Copy this file to .env and fill in your values
# Never commit .env to Git
# (.env is the ONE place for local secrets — the old neon.env was merged into it 2026-07-08)

# AlloyDB / PostgreSQL (points at Neon in local dev)
ALLOYDB_HOST=your-db-host
ALLOYDB_DB=your_database
ALLOYDB_USER=postgres
ALLOYDB_PASSWORD=your_password_here

# Stock-footage downloads for the perception corpus (optional)
# PEXELS_API_KEY=...

# GCP
GCP_PROJECT=your-gcp-project-id
GCP_REGION=us-central1
GCS_BUCKET=your-gcs-bucket

# Stage 5 — Sandbox Engine (Cloud Run, gen2/gVisor)
SANDBOX_URL=https://your-sandbox-xxxxx.run.app

# Eval AI judge (reference-only scorer; either key works, Claude preferred if both)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ── Auth + abuse/billing guardrails (P0) ─────────────────────────────
# APP_ACCESS_KEYS: comma-separated "name:key" login passwords. Empty = NO auth (local dev only).
#   The Docker image bakes APP_ENV=prod, so any Cloud Run deploy WITHOUT this refuses to start
#   (fail-closed — never launches ungated). Local uvicorn leaves APP_ENV unset → dev stays open.
# APP_ACCESS_KEYS=kenny:9f3k2x7q,guest:7x2qd8m4   # names starting with "guest" get the cheap tier
# APP_DEV_MODE=1                                  # only to run the container ungated for debugging
#
# Rate limiting (pipeline/ratelimit.py): defaults are generous — real users won't hit them; runaways do.
# Needs Redis (below); without it the limiter no-ops. The real hard floor is the Gemini spend cap
# (see docs/billing-guardrails.md) — this is the app-layer softener so you don't reach that cap.
# USE_RATE_LIMIT=1
# RL_REQ_PER_MIN=30                # named user requests/min
# RL_REQ_PER_MIN_GUEST=8           # anon/guest requests/min (tighter)
# RL_IP_REQ_PER_MIN=40             # per-IP requests/min (small tier only)
# RL_DAILY_COST_USD=2.0            # named user $/day cap
# RL_DAILY_COST_USD_GUEST=0.20     # anon/guest $/day cap
# RL_SESSION_COST_USD=0.75         # per-session $ cap
# RL_GLOBAL_DAILY_COST_USD=15.0    # whole-service $/day circuit breaker
# QUERY_MAX_CHARS=8000             # max chars per question

# Session store backend: sqlite (default, single node) | redis (shared, multi-instance)
# Set SESSION_BACKEND=redis on Cloud Run so all replicas share session memory.
# Connect via EITHER TCP (REDIS_URL) OR Upstash REST (UPSTASH_REDIS_REST_URL + _TOKEN):
SESSION_BACKEND=sqlite
REDIS_URL=                          # TCP, e.g. rediss://default:<pwd>@<host>.upstash.io:6379
UPSTASH_REDIS_REST_URL=             # HTTP REST, e.g. https://<name>.upstash.io
UPSTASH_REDIS_REST_TOKEN=
